<Window x:Class="KgmExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="kgmexporter"
        Width="500" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="kgmexporter" Foreground="Gray" Margin="0,0,0,6"/>

        <TabControl Grid.Row="1" x:Name="Tabs">
            <TabItem Header="Upload">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="UploadBtn" Content="Upload..." Padding="10,4" Click="UploadBtn_Click">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="UploadMenu" Placement="Bottom">
                                    <MenuItem Header="Files... (.kgmap, .zip, .rar)" Click="UploadFiles_Click"/>
                                    <MenuItem Header="Folder(s)..." Click="UploadFolders_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="CancelUploadBtn" Content="Cancel" Padding="10,4" Margin="6,0,0,0" Click="CancelUploadBtn_Click"/>
                        <TextBlock Text="(.kgmap / .zip / .rar / folders -&gt; archive.org)"
                                   Foreground="DarkGray" FontSize="11"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <CheckBox Grid.Row="1" x:Name="ArchiveDedupBox"
                              Content="Skip maps already on archive.org"
                              IsChecked="True"
                              Margin="0,10,0,0"
                              Checked="ArchiveDedupBox_Changed"
                              Unchecked="ArchiveDedupBox_Changed"/>
                    <CheckBox Grid.Row="1" x:Name="UploadArchivesAsIsBox"
                              Content="Upload .zip / .rar as-is (faster, no per-map browsing)"
                              IsChecked="False"
                              Margin="0,32,0,0"
                              Checked="UploadArchivesAsIsBox_Changed"
                              Unchecked="UploadArchivesAsIsBox_Changed"/>

                    <Expander Grid.Row="2" x:Name="AdvancedExpander" Header="Advanced options" Margin="0,10,0,0" Foreground="Gray">
                        <StackPanel Margin="4,6,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Upload delay (ms):" VerticalAlignment="Center" Margin="0,0,6,0" Width="140"/>
                                <TextBox x:Name="UploadDelayBox" Text="0" Width="60" Padding="4,2" TextAlignment="Center" LostFocus="UploadTuning_LostFocus"/>
                                <TextBlock Text="raise if blocked" Foreground="DarkGray" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Retry delay (ms):" VerticalAlignment="Center" Margin="0,0,6,0" Width="140"/>
                                <TextBox x:Name="RetryDelayBox" Text="1000" Width="60" Padding="4,2" TextAlignment="Center" LostFocus="UploadTuning_LostFocus"/>
                                <TextBlock Text="wait before retry" Foreground="DarkGray" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                <Button x:Name="S3KeysBtn" Content="Set archive.org S3 keys..." Padding="8,3" Click="S3KeysBtn_Click"/>
                                <TextBlock Text="only if ours get banned" Foreground="DarkGray" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <TextBlock Grid.Row="3" FontSize="11" Foreground="Gray"
                               Margin="0,10,0,0" TextWrapping="Wrap" VerticalAlignment="Bottom">
                        Uploaded maps go to
                        <Hyperlink NavigateUri="https://archive.org/details/kogama-maps-kgmexporter" RequestNavigate="ArchiveLink_RequestNavigate">
                            archive.org/details/kogama-maps-kgmexporter
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </TabItem>

            <TabItem Header="Convert">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right" x:Name="BrowseKgmapBtn" Content="Browse" Padding="8,2" Margin="6,0,0,0" Click="BrowseKgmapBtn_Click"/>
                        <Grid>
                            <TextBox x:Name="KgmapPathBox" Padding="4" TextChanged="KgmapPathBox_TextChanged"/>
                            <TextBlock x:Name="KgmapPlaceholder"
                                       Text="pick a .kgmap file"
                                       Foreground="DarkGray"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </DockPanel>
                    <Button Grid.Row="1" x:Name="ConvertBtn" Content="Convert to .obj" Height="28" Margin="0,8,0,0" Click="ConvertBtn_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Margin="0,6,0,0">
            <TextBlock x:Name="StatusLabel" Foreground="Gray" FontSize="11"/>
            <TextBlock x:Name="ArchiveStatusLabel" Foreground="#222" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" Margin="0,4,0,0"/>
        </StackPanel>
    </Grid>
</Window>
