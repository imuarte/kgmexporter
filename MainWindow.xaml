<Window x:Class="KgmExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="kgmexporter"
        Width="440" Height="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" x:Name="AccountBtn" Content="Sign in" Padding="8,2" Click="AccountBtn_Click"/>
            <TextBlock VerticalAlignment="Center" Text="kgmexporter" Foreground="Gray"/>
        </DockPanel>

        <TabControl Grid.Row="1" x:Name="Tabs">
            <TabItem Header="Save">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <Border DockPanel.Dock="Right"
                                Width="20" Height="20"
                                Margin="6,0,0,0"
                                CornerRadius="10"
                                BorderBrush="#888" BorderThickness="1"
                                Background="#EEEEEE"
                                VerticalAlignment="Center"
                                Cursor="Help"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="20000">
                            <Border.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" Text="Supported URLs"/>
                                        <TextBlock Text="• Game: /games/play/&lt;id&gt;"/>
                                        <TextBlock Text="• Project: /build/&lt;owner&gt;/project/&lt;id&gt;"/>
                                        <TextBlock Text="• Profile: /profile/&lt;id&gt; (saves every game)"/>
                                        <TextBlock Margin="0,4,0,0" Text="Domains: www.kogama.com, kogama.com.br, friends.kogama.com"/>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="i"
                                       FontFamily="Segoe UI"
                                       FontStyle="Italic"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="#444"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Grid>
                            <TextBox x:Name="UrlBox" Padding="4" TextChanged="UrlBox_TextChanged"/>
                            <TextBlock x:Name="UrlPlaceholder"
                                       Text="paste a kogama game or profile url"
                                       Foreground="DarkGray"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </DockPanel>
                    <CheckBox Grid.Row="1" x:Name="AvatarModeBox" Margin="0,8,0,0" Content="Join as avatar editor (needs login)"/>
                    <Button Grid.Row="2" x:Name="SaveBtn" Content="Save .kgmap" Height="28" Margin="0,8,0,0" Click="SaveBtn_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Convert">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right" x:Name="BrowseKgmapBtn" Content="Browse" Padding="8,2" Margin="6,0,0,0" Click="BrowseKgmapBtn_Click"/>
                        <Grid>
                            <TextBox x:Name="KgmapPathBox" Padding="4" TextChanged="KgmapPathBox_TextChanged"/>
                            <TextBlock x:Name="KgmapPlaceholder"
                                       Text="pick a .kgmap file"
                                       Foreground="DarkGray"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </DockPanel>
                    <Button Grid.Row="1" x:Name="ConvertBtn" Content="Convert to .obj" Height="28" Margin="0,8,0,0" Click="ConvertBtn_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Margin="0,6,0,0">
            <TextBlock x:Name="StatusLabel" Foreground="Gray" FontSize="11"/>
            <TextBlock FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap">
                Please share what you save on
                <Hyperlink NavigateUri="https://archive.org/upload" RequestNavigate="ArchiveLink_RequestNavigate">
                    archive.org/upload
                </Hyperlink>
                so Kogama maps stay preserved.
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
