<Window x:Class="KgmExporter.FirstLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SAVE KOGAMA"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="&#x2665;"
                   FontFamily="Segoe UI Symbol"
                   FontSize="44"
                   Foreground="#e94f4f"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="KOGAMA shuts down in"
                   FontSize="14"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="2"
                   x:Name="CountdownLabel"
                   Text="--d --h --m --s"
                   FontWeight="Bold"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,6"/>

        <TextBlock Grid.Row="3" Visibility="Collapsed"/>

        <TextBlock Grid.Row="4"
                   Text="Every map, avatar and model disappears forever."
                   FontSize="13"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5"
                   FontSize="12"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center">
            kgmexporter can automatically upload every .kgmap you save
            to archive.org after download.
        </TextBlock>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="YesBtn"
                    Content="auto-upload maps"
                    Width="130" Height="28"
                    Margin="0,0,8,0"
                    Click="YesBtn_Click"/>
            <Button x:Name="NoBtn"
                    Content="not now"
                    Width="100" Height="28"
                    Click="NoBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
