<Window x:Class="KgmExporter.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in"
        Width="280" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBox x:Name="UsernameBox" Padding="4" TextChanged="UsernameBox_TextChanged"/>
            <TextBlock x:Name="UsernamePlaceholder"
                       Text="username"
                       Foreground="DarkGray"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Grid>
        <PasswordBox Grid.Row="1" x:Name="PasswordBox" Padding="4" Margin="0,6,0,0"/>
        <ComboBox Grid.Row="2" x:Name="RegionBox" SelectedIndex="0" Margin="0,6,0,0">
            <ComboBoxItem Content="www"/>
            <ComboBoxItem Content="br"/>
            <ComboBoxItem Content="friends"/>
        </ComboBox>

        <TextBlock Grid.Row="3" x:Name="StatusLabel" Foreground="Firebrick" Margin="0,6,0,0" FontSize="11" TextWrapping="Wrap"/>

        <Button Grid.Row="4" x:Name="SignInBtn" Content="Sign in" Height="28" Margin="0,6,0,0" IsDefault="True" Click="SignInBtn_Click"/>
    </Grid>
</Window>
